// Autenticação gerenciada pelo Supabase Auth (tabela auth.users).
// Prisma gerencia apenas as tabelas de negócio.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String     @id
  name      String?
  company   String?
  role      Role       @default(MEMBER)
  ativo     Boolean    @default(true)
  empresaId String     @map("empresa_id")
  empresa   Empresa    @relation(fields: [empresaId], references: [id])
  pesquisas Pesquisa[]
  criadoEm  DateTime   @default(now()) @map("criado_em")

  @@index([empresaId])
  @@map("profiles")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Pesquisa {
  id           String         @id @default(cuid())
  titulo       String
  descricao    String?
  status       PesquisaStatus @default(RASCUNHO)
  profileId    String         @map("profile_id")
  profile      Profile        @relation(fields: [profileId], references: [id])
  empresaId    String         @map("empresa_id")
  empresa      Empresa        @relation(fields: [empresaId], references: [id])
  perguntas    Pergunta[]
  envios       Envio[]
  disparoJobs  DisparoJob[]
  importacoesDestinatarios ImportacaoDestinatariosLote[]
  criadaEm     DateTime       @default(now()) @map("criada_em")
  atualizadaEm DateTime       @updatedAt @map("atualizada_em")

  @@index([empresaId])
  @@map("pesquisas")
}

enum PesquisaStatus {
  RASCUNHO
  ATIVA
  ENCERRADA
}

model Pergunta {
  id         String         @id @default(cuid())
  texto      String
  tipo       TipoPergunta   @default(MULTIPLA_ESCOLHA)
  ordem      Int            @default(0)
  pesquisaId String         @map("pesquisa_id")
  pesquisa   Pesquisa       @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  opcoes     Opcao[]
  itens      RespostaItem[]

  @@map("perguntas")
}

enum TipoPergunta {
  MULTIPLA_ESCOLHA
  TEXTO_LIVRE
  ESCALA
}

model Opcao {
  id         String         @id @default(cuid())
  texto      String
  ordem      Int            @default(0)
  perguntaId String         @map("pergunta_id")
  pergunta   Pergunta       @relation(fields: [perguntaId], references: [id], onDelete: Cascade)
  itens      RespostaItem[]

  @@map("opcoes")
}

model Envio {
  id           String      @id @default(cuid())
  pesquisaId   String      @map("pesquisa_id")
  pesquisa     Pesquisa    @relation(fields: [pesquisaId], references: [id])
  jobId        String?     @map("job_id")
  job          DisparoJob? @relation(fields: [jobId], references: [id])
  nome         String
  email        String
  token        String      @unique @default(cuid())
  status       EnvioStatus @default(PENDENTE)
  tentativas   Int         @default(0)
  ultimaTentativaEm DateTime? @map("ultima_tentativa_em")
  proximoRetryEm DateTime? @map("proximo_retry_em")
  erroCodigo   String?     @map("erro_codigo")
  enviadoEm    DateTime?   @map("enviado_em")
  respondidoEm DateTime?   @map("respondido_em")
  expiraEm     DateTime?   @map("expira_em")
  erroMsg      String?     @map("erro_msg")
  resposta     Resposta?
  criadoEm     DateTime    @default(now()) @map("criado_em")

  @@index([jobId, status, proximoRetryEm])
  @@map("envios")
}

enum EnvioStatus {
  PENDENTE
  PROCESSANDO
  ENVIADO
  RESPONDIDO
  EXPIRADO
  ERRO
}

model DisparoJob {
  id          String          @id @default(cuid())
  pesquisaId  String          @map("pesquisa_id")
  pesquisa    Pesquisa        @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  empresaId   String          @map("empresa_id")
  empresa     Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  status      DisparoJobStatus @default(PENDENTE)
  total       Int             @default(0)
  processados Int             @default(0)
  enviados    Int             @default(0)
  erros       Int             @default(0)
  iniciadoEm  DateTime?       @map("iniciado_em")
  finalizadoEm DateTime?      @map("finalizado_em")
  lockToken   String?         @map("lock_token")
  lockAt      DateTime?       @map("lock_at")
  ultimoErro  String?         @map("ultimo_erro")
  criadoEm    DateTime        @default(now()) @map("criado_em")
  atualizadoEm DateTime       @updatedAt @map("atualizado_em")
  envios      Envio[]

  @@index([empresaId, pesquisaId, status])
  @@map("disparo_jobs")
}

enum DisparoJobStatus {
  PENDENTE
  PROCESSANDO
  CONCLUIDO
  ERRO
}

model Resposta {
  id        String         @id @default(cuid())
  envioId   String         @unique @map("envio_id")
  envio     Envio          @relation(fields: [envioId], references: [id])
  itens     RespostaItem[]
  criadaEm  DateTime       @default(now()) @map("criada_em")

  @@map("respostas")
}

model RespostaItem {
  id          String   @id @default(cuid())
  respostaId  String   @map("resposta_id")
  resposta    Resposta @relation(fields: [respostaId], references: [id])
  perguntaId  String   @map("pergunta_id")
  pergunta    Pergunta @relation(fields: [perguntaId], references: [id])
  opcaoId     String?  @map("opcao_id")
  opcao       Opcao?   @relation(fields: [opcaoId], references: [id])
  textoLivre  String?  @map("texto_livre")
  valorEscala Int?     @map("valor_escala")

  @@map("resposta_itens")
}

model Empresa {
  id           String     @id @default(cuid())
  nome         String
  slug         String?    @unique
  profiles     Profile[]
  pesquisas    Pesquisa[]
  disparoJobs  DisparoJob[]
  importacoesDestinatarios ImportacaoDestinatariosLote[]
  criadaEm     DateTime   @default(now()) @map("criada_em")
  atualizadaEm DateTime   @updatedAt @map("atualizada_em")

  @@map("empresas")
}

model ImportacaoDestinatariosLote {
  id         String   @id @default(cuid())
  pesquisaId String   @map("pesquisa_id")
  pesquisa   Pesquisa @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  empresaId  String   @map("empresa_id")
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profileId  String?  @map("profile_id")
  formato    String
  nomeArquivo String? @map("nome_arquivo")
  totalLinhas Int     @map("total_linhas")
  validos    Int
  invalidos  Int
  duplicados Int
  rejeicoes  Json?
  criadaEm   DateTime @default(now()) @map("criada_em")

  @@index([pesquisaId, criadaEm])
  @@index([empresaId, criadaEm])
  @@map("importacao_destinatarios_lotes")
}
